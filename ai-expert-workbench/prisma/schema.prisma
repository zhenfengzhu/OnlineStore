generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContentAsset {
  id          String   @id @default(cuid())
  type        String
  title       String
  body        String
  tags        String?
  source      String
  parentId    String?
  variantType String?
  status      String   @default("draft")
  isFavorite  Boolean  @default(false)
  coverImage  String?
  coverText   String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([parentId])
}

model CalendarItem {
  id         String   @id @default(cuid())
  day        Int
  topic      String
  format     String
  angle      String
  assetTitle String?
  goal       String?
  status     String   @default("planned")
  createdAt  DateTime @default(now())

  @@index([day])
}

model ExpertSkill {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("Sparkles")
  prompt      String
  placeholder String   @default("")
  inputLabel  String   @default("请输入内容")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
